# API Configuration
# VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_BASE_URL=https://marine-flight-backend.vercel.app/
VITE_API_TIMEOUT=30000

# Authentication
VITE_AUTH_TOKEN_KEY=offshore_crm_auth_token
VITE_REFRESH_TOKEN_KEY=offshore_crm_refresh_token
VITE_SUPERADMIN_TOKEN_KEY=offshore_superadmin_token

# Application Settings
VITE_APP_NAME=Offshore CRM
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# External Services (if needed)
# VITE_GOOGLE_CLIENT_ID=your_google_client_id
# VITE_SLACK_CLIENT_ID=your_slack_client_id
# VITE_EMAIL_SERVICE_API_KEY=your_email_api_key

# File Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# Pagination
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# Feature Flags (optional)
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_ERROR_TRACKING=false
