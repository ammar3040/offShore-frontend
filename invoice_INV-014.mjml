<mjml>
  <mj-head>
    <mj-title>Invoice INV-014 — Lynq Travel</mj-title>
    <mj-attributes>
      <mj-all font-family="Arial, Helvetica, sans-serif" />
      <mj-text color="#1f2733" font-size="13px" line-height="1.5" />
    </mj-attributes>
    <mj-style>
      .grey-label { color:#8b94a4; font-size:11px; letter-spacing:0.6px; text-transform:uppercase; }
      .val-bold { color:#1f2733; font-size:14px; font-weight:bold; }
      .blue-amt { color:#2f6fb5; font-weight:bold; }
      .desc-table td { padding:0; }
      .tot-table td { padding:6px 0; }
    </mj-style>
  </mj-head>

  <mj-body background-color="#ffffff" width="640px">

    <!-- HEADER: logo + INVOICE title -->
    <mj-section padding="28px 28px 8px 28px">
      <mj-column width="50%" vertical-align="middle">
        <mj-image src="data:image/png;base64," alt="Lynq Travel" width="190px" align="left" padding="0" />
      </mj-column>
      <mj-column width="50%" vertical-align="middle">
        <mj-text align="right" color="#1e2a44" font-size="40px" font-weight="bold" letter-spacing="1px" padding="0">INVOICE</mj-text>
      </mj-column>
    </mj-section>

    <!-- Thick navy divider -->
    <mj-section padding="8px 28px 0 28px">
      <mj-column>
        <mj-divider border-width="3px" border-color="#1e2a44" padding="0" />
      </mj-column>
    </mj-section>

    <!-- SUMMARY BAR -->
    <mj-section padding="20px 28px 0 28px">
      <mj-column>
        <mj-table cellpadding="0" cellspacing="0" padding="0" font-size="13px">
          <tr style="background:#f6f8fa; border-top:1px solid #e2e6ec; border-bottom:1px solid #e2e6ec;">
            <td style="padding:10px 12px; width:23%; color:#8b94a4; font-size:11px; letter-spacing:0.6px; text-transform:uppercase;">Invoice No.</td>
            <td style="padding:10px 12px; width:27%; color:#8b94a4; font-size:11px; letter-spacing:0.6px; text-transform:uppercase;">Date of Issue</td>
            <td style="padding:10px 12px; width:25%; color:#8b94a4; font-size:11px; letter-spacing:0.6px; text-transform:uppercase;">Due Date</td>
            <td style="padding:10px 12px; width:25%; color:#8b94a4; font-size:11px; letter-spacing:0.6px; text-transform:uppercase;">Amount Due</td>
          </tr>
          <tr style="border-bottom:1px solid #e2e6ec;">
            <td style="padding:8px 12px; color:#1f2733; font-size:14px; font-weight:bold;">INV-014</td>
            <td style="padding:8px 12px; color:#1f2733; font-size:14px; font-weight:bold;">29 May 2026</td>
            <td style="padding:8px 12px; color:#1f2733; font-size:14px; font-weight:bold;">30 May 2026</td>
            <td style="padding:8px 12px; color:#2f6fb5; font-size:14px; font-weight:bold;">&pound;872.92</td>
          </tr>
        </mj-table>
      </mj-column>
    </mj-section>

    <!-- FROM / TO -->
    <mj-section padding="22px 28px 0 28px">
      <mj-column width="50%" vertical-align="top">
        <mj-text css-class="grey-label" color="#8b94a4" font-size="11px" letter-spacing="0.6px" text-transform="uppercase" padding="0 0 6px 0">From</mj-text>
        <mj-text font-weight="bold" font-size="14px" padding="0 0 2px 0">Lynq Travel</mj-text>
        <mj-text padding="0">United Kingdom</mj-text>
        <mj-text padding="14px 0 0 0">hello@lynq.click</mj-text>
      </mj-column>
      <mj-column width="50%" vertical-align="top">
        <mj-text css-class="grey-label" color="#8b94a4" font-size="11px" letter-spacing="0.6px" text-transform="uppercase" padding="0 0 6px 0">To</mj-text>
        <mj-text font-weight="bold" font-size="14px" padding="0 0 2px 0">Subseaquence Ltd</mj-text>
        <mj-text padding="0" line-height="1.6">Unit 9A Kent House<br/>19 Bourne Road<br/>Old Bexley Business Park<br/>Bexley, Kent, DA5 1LR<br/>United Kingdom</mj-text>
        <mj-text padding="14px 0 0 0">FAO: Rex Makin</mj-text>
      </mj-column>
    </mj-section>

    <!-- LINE ITEMS -->
    <mj-section padding="22px 28px 0 28px">
      <mj-column>
        <mj-table cellpadding="0" cellspacing="0" padding="0" font-size="13px" css-class="desc-table">
          <tr style="background:#1f3a5f; color:#ffffff;">
            <td style="padding:11px 14px; font-size:12px; font-weight:bold; letter-spacing:0.5px;">DESCRIPTION</td>
            <td style="padding:11px 10px; font-size:12px; font-weight:bold; letter-spacing:0.5px; text-align:center; width:9%;">QTY</td>
            <td style="padding:11px 10px; font-size:12px; font-weight:bold; letter-spacing:0.5px; text-align:right; width:20%;">UNIT PRICE</td>
            <td style="padding:11px 14px; font-size:12px; font-weight:bold; letter-spacing:0.5px; text-align:right; width:20%;">AMOUNT</td>
          </tr>
          <tr style="border-left:1px solid #e2e6ec; border-right:1px solid #e2e6ec; border-bottom:1px solid #e2e6ec;">
            <td style="padding:16px 14px; vertical-align:top; color:#1f2733; line-height:1.6;">
              <span style="font-weight:bold;">Equinox 2</span><br/>
              Passenger: Darren Quigley<br/>
              Flights booked &mdash; Dublin &rarr; Dubai &rarr; Melbourne<br/>
              Departure: 2 June 2026<br/>
              Single
            </td>
            <td style="padding:16px 10px; vertical-align:top; text-align:center; color:#1f2733;">1</td>
            <td style="padding:16px 10px; vertical-align:top; text-align:right; color:#1f2733;">&pound;872.92</td>
            <td style="padding:16px 14px; vertical-align:top; text-align:right; color:#1f2733;">&pound;872.92</td>
          </tr>
        </mj-table>
      </mj-column>
    </mj-section>

    <!-- TOTALS -->
    <mj-section padding="14px 28px 0 28px">
      <mj-column width="55%">
        <mj-text padding="0">&nbsp;</mj-text>
      </mj-column>
      <mj-column width="45%">
        <mj-table cellpadding="0" cellspacing="0" padding="0" font-size="13px" css-class="tot-table">
          <tr>
            <td style="padding:6px 0; color:#8b94a4;">Subtotal</td>
            <td style="padding:6px 0; text-align:right; font-weight:bold; color:#1f2733;">&pound;872.92</td>
          </tr>
          <tr style="border-bottom:1px solid #e2e6ec;">
            <td style="padding:6px 0 12px 0; color:#8b94a4;">VAT (0%)</td>
            <td style="padding:6px 0 12px 0; text-align:right; font-weight:bold; color:#1f2733;">&pound;0.00</td>
          </tr>
          <tr style="background:#eef1f5;">
            <td style="padding:12px 10px; font-weight:bold; font-size:16px; color:#1f2733;">TOTAL DUE</td>
            <td style="padding:12px 10px; text-align:right; font-weight:bold; font-size:16px; color:#2f6fb5;">&pound;872.92</td>
          </tr>
        </mj-table>
      </mj-column>
    </mj-section>

    <!-- FOOTER -->
    <mj-section padding="30px 28px 30px 28px">
      <mj-column>
        <mj-divider border-width="1px" border-color="#e9edf2" padding="0 0 18px 0" />
        <mj-text align="center" color="#9aa3b2" font-size="11px" padding="0">
          Payment due by 30 May 2026&nbsp;&nbsp;|&nbsp;&nbsp;Please include INV-014 with your payment&nbsp;&nbsp;|&nbsp;&nbsp;hello@lynq.click
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
