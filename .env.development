# API Base URL. Set to /api to use the local Vite proxy to completely avoid CORS.
VITE_API_BASE_URL=https://offshore-backend-x8wo.onrender.com

# Target server for the Vite proxy (only active if VITE_API_BASE_URL=/api)
VITE_API_PROXY_TARGET=https://offshore-backend-x8wo.onrender.com

VITE_API_TIMEOUT=30000

# Authentication
VITE_AUTH_TOKEN_KEY=offshore_crm_auth_token
VITE_REFRESH_TOKEN_KEY=offshore_crm_refresh_token
VITE_SUPERADMIN_TOKEN_KEY=offshore_superadmin_token

